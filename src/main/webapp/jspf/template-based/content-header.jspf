<%-- any content can be specified here e.g.: --%>
<%@ page pageEncoding="UTF-8" %>
<!-- Content Header (Page header) -->

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>${param.title}</h1>
                <small>${param.subtitle}</small>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>
<!-- /.content-header -->